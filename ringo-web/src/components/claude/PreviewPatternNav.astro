---
// Claude デザイン試作：パターン切り替えナビ
// 各試作ページの最上部に表示し、試作同士を行き来できるようにする
import { PATTERNS } from '../../data/claude/preview';

interface Props {
	current?: string;
}

const { current } = Astro.props;
const baseUrl = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const previewBase = `${baseUrl}design-preview/claude/`;
---

<nav class="cp-pattern-nav" aria-label="デザイン試作の切り替え">
	<a class="nav-home" href={previewBase}>CLAUDE DESIGN PREVIEW</a>
	<div class="nav-links">
		{
			PATTERNS.map((pattern) => (
				<a href={`${previewBase}${pattern.slug}`} aria-current={pattern.slug === current ? 'page' : undefined}>
					{pattern.short}
				</a>
			))
		}
	</div>
</nav>

<style>
	.cp-pattern-nav {
		display: flex;
		align-items: center;
		gap: 1.25rem;
		background: #14211d;
		color: #e8ede9;
		padding: 0.6rem var(--container-pad-x);
		font-size: 0.8rem;
	}
	.nav-home {
		color: #ffd166;
		font-weight: 700;
		letter-spacing: 0.14em;
		min-height: var(--tap-min);
		display: inline-flex;
		align-items: center;
		white-space: nowrap;
	}
	.nav-links {
		display: flex;
		gap: 0.25rem;
		overflow-x: auto;
		-webkit-overflow-scrolling: touch;
	}
	.nav-links a {
		color: #e8ede9;
		white-space: nowrap;
		padding: 0.5rem 0.7rem;
		min-height: var(--tap-min);
		display: inline-flex;
		align-items: center;
		border-radius: 6px;
	}
	.nav-links a:hover {
		background: rgba(255, 255, 255, 0.12);
		opacity: 1;
	}
	.nav-links a[aria-current='page'] {
		background: rgba(255, 209, 102, 0.18);
		color: #ffd166;
		font-weight: 700;
	}

	@media (max-width: 768px) {
		.cp-pattern-nav {
			flex-direction: column;
			align-items: flex-start;
			gap: 0;
		}
		.nav-links {
			width: 100%;
		}
	}
</style>
