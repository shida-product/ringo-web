---
// Claude デザイン試作：セクション見出し（英字ラベル + 日本語見出し + リード）
interface Props {
	label: string;
	title: string;
	lead?: string;
	align?: 'left' | 'center';
}

const { label, title, lead, align = 'left' } = Astro.props;
---

<header class:list={['cp-section-header', `is-${align}`]}>
	<p class="cp-eyebrow">{label}</p>
	<h2>{title}</h2>
	{lead && <p class="lead text-pretty">{lead}</p>}
</header>

<style>
	.cp-section-header {
		margin-bottom: 2.25rem;
	}
	.cp-section-header.is-center {
		text-align: center;
	}
	.cp-eyebrow {
		color: var(--cp-primary);
		font-size: 0.8rem;
		font-weight: 700;
		letter-spacing: var(--cp-eyebrow-tracking);
		text-transform: uppercase;
		margin-bottom: 0.5rem;
	}
	h2 {
		font-size: clamp(1.55rem, 3.2vw, 2.1rem);
		margin-bottom: 0.75rem;
		line-height: 1.35;
	}
	.lead {
		color: var(--cp-text-muted);
		max-width: 40em;
	}
	.cp-section-header.is-center .lead {
		margin-inline: auto;
	}
</style>
