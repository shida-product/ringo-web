---
// Claude デザイン試作：アクセスパネル（住所・地図・最寄り駅）
import { SITE } from '../../data/site';
---

<div class="cp-access-panel" id="access">
	<div class="info">
		<div class="head">
			<i data-lucide="map-pin" aria-hidden="true"></i>
			<h3>アクセス</h3>
		</div>
		<p class="station"><strong>町屋駅より徒歩5分</strong></p>
		<p class="line-name">千代田線、さくらトラム（都電荒川線）</p>
		<p class="address">
			{SITE.postalCode}<br />
			<a href={SITE.mapUrl} target="_blank" rel="noopener noreferrer">
				{SITE.address}
				<i data-lucide="external-link" aria-hidden="true"></i>
			</a>
		</p>
		<a class="tel" href={SITE.telLink}>
			<i data-lucide="phone" aria-hidden="true"></i>
			{SITE.tel}
		</a>
	</div>
	<div class="map-embed">
		<iframe
			src="https://maps.google.com/maps?q=%E3%82%8A%E3%82%93%E3%81%94%E3%81%A1%E3%82%83%E3%82%93%E8%96%AC%E5%B1%80%20%E6%9D%B1%E4%BA%AC%E9%83%BD%E8%8D%92%E5%B7%9D%E5%8C%BA%E8%8D%92%E5%B7%9D5-11-18&t=&z=16&ie=UTF8&iwloc=&output=embed"
			title="りんごちゃん薬局 地図"
			width="100%"
			height="100%"
			style="border:0;"
			allowfullscreen=""
			loading="lazy"
			referrerpolicy="no-referrer-when-downgrade"></iframe>
	</div>
</div>

<style>
	.cp-access-panel {
		display: grid;
		grid-template-columns: minmax(260px, 1fr) 1.4fr;
		gap: 1.5rem;
		background: var(--cp-surface);
		border: 1px solid var(--cp-border);
		border-radius: var(--cp-radius-lg);
		box-shadow: var(--cp-shadow);
		padding: 1.75rem;
	}
	.head {
		display: flex;
		align-items: center;
		gap: 0.6rem;
		margin-bottom: 1rem;
	}
	.head :global(svg) {
		width: 24px;
		height: 24px;
		color: var(--cp-primary);
	}
	h3 {
		font-size: 1.25rem;
		margin: 0;
	}
	.station {
		font-size: 1.1rem;
		margin-bottom: 0.25rem;
	}
	.line-name {
		color: var(--cp-text-muted);
		font-size: 0.92rem;
		margin-bottom: 1rem;
	}
	.address {
		margin-bottom: 1.25rem;
	}
	.address a {
		color: var(--cp-text);
		text-decoration: underline;
		text-decoration-color: var(--cp-border);
		text-underline-offset: 4px;
		display: inline-flex;
		align-items: center;
		gap: 0.3rem;
		min-height: var(--tap-min);
	}
	.address a :global(svg) {
		width: 16px;
		height: 16px;
	}
	.tel {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		font-size: 1.3rem;
		font-weight: 700;
		color: var(--cp-accent);
		min-height: var(--tap-min);
	}
	.tel :global(svg) {
		width: 20px;
		height: 20px;
	}
	.map-embed {
		min-height: 260px;
		border-radius: var(--cp-radius);
		overflow: hidden;
		border: 1px solid var(--cp-border);
	}

	@media (max-width: 768px) {
		.cp-access-panel {
			grid-template-columns: 1fr;
			padding: 1.25rem;
		}
		.map-embed {
			min-height: 220px;
		}
	}
</style>
