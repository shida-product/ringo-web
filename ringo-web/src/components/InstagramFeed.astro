---
import { SITE } from '../data/site';

const posts = ['商品紹介', '薬局の日常', '健康相談'];
---

<section class="instagram-section container" aria-labelledby="instagram-title">
  <h2 id="instagram-title" class="section-title">Instagram</h2>
  <div class="instagram-grid">
    {posts.map((label) => (
      <div class="instagram-tile glass-panel">
        <i data-lucide="camera" aria-hidden="true"></i>
        <span>{label}</span>
      </div>
    ))}
  </div>
  <div class="instagram-cta">
    <a href={SITE.instagramUrl} target="_blank" rel="noopener noreferrer" class="button-accent">Instagramで見る</a>
  </div>
</section>

<style>
  .instagram-section { margin-top: 4rem; }
  .instagram-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 1rem; }
  .instagram-tile { aspect-ratio: 1 / 1; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 0.75rem; color: var(--color-primary); }
  .instagram-tile :global(svg) { width: 40px; height: 40px; }
  .instagram-tile span { font-weight: 700; color: var(--color-text); }
  .instagram-cta { text-align: center; margin-top: 1.5rem; }
  @media (max-width: 768px) { .instagram-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); } .instagram-section { margin-top: 3rem; } }
</style>
