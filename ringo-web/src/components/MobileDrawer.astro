---
import { NAV_ITEMS, withBaseUrl } from '../data/navigation';

interface Props { baseUrl: string; }
const { baseUrl } = Astro.props;
---

<div class="mobile-drawer" id="mobile-drawer" aria-hidden="true">
  <button class="drawer-close-btn" id="drawer-close-btn" aria-label="メニューを閉じる">
    <i data-lucide="x"></i>
  </button>
  <nav aria-label="モバイルメニュー">
    <ul>
      {NAV_ITEMS.map((item) => <li><a href={withBaseUrl(baseUrl, item.href)}>{item.label}</a></li>)}
    </ul>
  </nav>
</div>
<div class="drawer-overlay" id="drawer-overlay"></div>

<style>
  .mobile-drawer,
  .drawer-overlay { display: none; }

  @media (max-width: 768px) {
    .mobile-drawer {
      display: flex;
      flex-direction: column;
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: var(--color-surface);
      z-index: 10000;
      padding: 5rem 2rem 8rem;
      overflow-y: auto;
      transform: translateX(100%);
      transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      visibility: hidden;
    }
    .mobile-drawer.is-open { transform: translateX(0); visibility: visible; }
    .drawer-close-btn {
      position: absolute;
      top: 1rem;
      right: 1rem;
      background: transparent;
      border: none;
      cursor: pointer;
      color: var(--color-text);
      width: var(--tap-min);
      height: var(--tap-min);
      display: flex;
      align-items: center;
      justify-content: center;
      border-radius: 8px;
    }
    .drawer-close-btn:hover { background: rgba(0,0,0,0.05); }
    .mobile-drawer nav ul { list-style: none; display: flex; flex-direction: column; gap: 0; }
    .mobile-drawer nav a {
      display: block;
      font-size: 1.2rem;
      font-weight: 700;
      color: var(--color-text);
      padding: 1.1rem 0;
      border-bottom: 1px solid rgba(0,0,0,0.06);
      text-align: center;
      text-decoration: none;
    }
    .mobile-drawer nav a:hover { color: var(--color-primary); opacity: 1; }
    .drawer-overlay {
      display: block;
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.4);
      z-index: 9999;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.3s ease;
    }
    .drawer-overlay.is-open { opacity: 1; pointer-events: auto; }
  }
</style>
