---
import PreviewLayout from '../../layouts/PreviewLayout.astro';
import ActionLinks from '../../components/ActionLinks.astro';
import HoursPanel from '../../components/HoursPanel.astro';
import AccessPanel from '../../components/AccessPanel.astro';
import ServiceCards from '../../components/ServiceCards.astro';
import CtaBand from '../../components/CtaBand.astro';
import PreviewPatternNav from '../../components/PreviewPatternNav.astro';
import exterior from '../../assets/images/Exterior_01.jpg';
import interior from '../../assets/images/Introspection.jpg';
---
<PreviewLayout title="Trust First Pharmacy" theme="trust-first-pharmacy" description="Codex再作成版。来局前に必要な情報を一画面で確認できる薬局デザイン案です。">
  <article class="codex-pattern pattern-trust">
    <section class="trust-hero">
      <div class="preview-container">
        <PreviewPatternNav />
        <div class="trust-grid">
          <div class="trust-copy">
            <span class="codex-kicker">Codex redesign / Trust First</span>
            <h1>はじめてでも、迷わず来られる薬局。</h1>
            <p class="codex-lede">営業時間、電話、LINE、地図をファーストビューに集約。高齢者・処方箋利用者が最短で行動できる堅実案です。</p>
            <div class="codex-actions-wrap"><ActionLinks /></div>
          </div>
          <div class="trust-info-card">
            <div class="codex-photo trust-photo"><img src={exterior.src} alt="りんごちゃん薬局の外観" /></div>
            <div class="trust-bottom"><HoursPanel /><AccessPanel /></div>
          </div>
        </div>
      </div>
    </section>
    <section class="preview-section"><div class="preview-container"><ServiceCards /><CtaBand title="処方箋はLINEで先に送れます" text="来局前の不安を減らし、受け取りまでを分かりやすく案内します。" /></div></section>
  </article>
</PreviewLayout>
