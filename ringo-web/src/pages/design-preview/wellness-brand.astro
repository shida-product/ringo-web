---
import PreviewLayout from '../../layouts/PreviewLayout.astro';
import ActionLinks from '../../components/ActionLinks.astro';
import ServiceCards from '../../components/ServiceCards.astro';
import HoursPanel from '../../components/HoursPanel.astro';
import CtaBand from '../../components/CtaBand.astro';
import PreviewPatternNav from '../../components/PreviewPatternNav.astro';
---
<PreviewLayout title="Wellness Brand" theme="wellness-brand" description="Codex再作成版。宣言・数字・流れでブランド感を出すデザイン案です。">
  <article class="codex-pattern pattern-wellness"><section class="wellness-hero"><div class="preview-container"><PreviewPatternNav /><div class="wellness-grid"><div class="wellness-declare"><span class="codex-kicker">Codex redesign / Wellness</span><h1>地域の健康を、待たせない。</h1><p>ブランドサイトのように、薬局の約束を先に見せる構成。</p></div><div class="wellness-panel"><ActionLinks /><ServiceCards /></div></div></div></section><section class="preview-section"><div class="preview-container data-row"><article><strong>5</strong><span>町屋駅徒歩約5分</span></article><article><strong>7</strong><span>土日も含めて営業</span></article><article><strong>LINE</strong><span>事前受付対応</span></article></div></section><section class="preview-section"><div class="preview-container"><HoursPanel /><CtaBand title="健康を支える3つの約束" text="待ち時間短縮、相談しやすさ、地域の暮らしへの近さを一つのブランドメッセージにまとめます。" /></div></section></article>
</PreviewLayout>
