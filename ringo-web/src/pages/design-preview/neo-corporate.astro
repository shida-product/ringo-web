---
import PreviewLayout from '../../layouts/PreviewLayout.astro';
import ActionLinks from '../../components/ActionLinks.astro';
import AccessPanel from '../../components/AccessPanel.astro';
import CtaBand from '../../components/CtaBand.astro';
import PreviewPatternNav from '../../components/PreviewPatternNav.astro';
import exterior from '../../assets/images/Signboard_01.jpg';
---
<PreviewLayout title="Neo Corporate" theme="neo-corporate" description="Codex再作成版。大きなタイポグラフィと非対称グリッドの前衛コーポレート案です。">
  <article class="codex-pattern pattern-neo"><section class="neo-hero"><div class="preview-container"><PreviewPatternNav /><h1 class="neo-title">RINGOCHAN<br />PHARMACY</h1><div class="neo-grid"><div class="neo-copy"><span class="codex-kicker">Codex redesign / Neo Corporate</span><p class="codex-lede">星街すいせい公式サイトのような強いタイポグラフィを、薬局必須情報を残したままコーポレート表現へ転用。</p><ActionLinks /></div><div class="neo-topics"><article><strong>TOPICS 01</strong><p>LINE受付で待ち時間を短縮。</p></article><article><strong>TOPICS 02</strong><p>荒川区・町屋の取扱い商品を発信。</p></article><article><strong>TOPICS 03</strong><p>土日営業の店舗情報を明確化。</p></article></div><div class="codex-photo neo-photo"><img src={exterior.src} alt="りんごちゃん薬局の看板" /></div></div></div></section><section class="preview-section"><div class="preview-container neo-service-board"><article><h2>Prescription</h2><p>処方箋受付を大きな情報ブロック化。</p></article><article><h2>OTC</h2><p>市販薬相談。</p></article><article><h2>Access</h2><AccessPanel /></article></div></section><section class="preview-section"><div class="preview-container"><CtaBand /></div></section></article>
</PreviewLayout>
