---
import PreviewLayout from '../../layouts/PreviewLayout.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import ActionLinks from '../../components/ActionLinks.astro';
import ServiceCards from '../../components/ServiceCards.astro';
import HoursPanel from '../../components/HoursPanel.astro';
import AccessPanel from '../../components/AccessPanel.astro';
import PreviewPatternNav from '../../components/PreviewPatternNav.astro';
import exterior from '../../assets/images/Exterior_02.jpg';
---
<PreviewLayout title="Local Editorial" theme="local-editorial" description="Codex再作成版。地域編集型のデザイン案です。">
  <article class="codex-pattern pattern-local">
    <section class="local-cover"><div class="preview-container"><PreviewPatternNav /><div class="local-cover-grid"><div><span class="codex-kicker">Codex redesign / Local Editorial</span><h1>町屋の暮らしに、近い薬局。</h1><p class="codex-lede">大きな写真、余白、英字ラベルを使い、道の駅・地域メディアのようにスクロールで表情が変わる構成です。</p></div><div class="codex-photo local-photo-main"><img src={exterior.src} alt="町屋のりんごちゃん薬局外観" /></div></div></div></section>
    <section class="preview-section"><div class="preview-container local-story"><aside class="local-toc"><div class="local-note-card">About Us<br />町屋の日常に近い相談先</div><div class="local-note-card">Products<br />商品と健康情報</div><div class="local-note-card">Access<br />迷わない店舗情報</div></aside><main><SectionHeader label="Consultation" title="処方箋も、市販薬も、日々の相談も。" lead="章立てで読み進める編集型。情報量が増えても整理しやすい案です。" /><ServiceCards /><div class="codex-actions-wrap"><ActionLinks /></div></main></div></section>
    <section class="preview-section"><div class="preview-container care-info"><HoursPanel /><AccessPanel /></div></section>
  </article>
</PreviewLayout>
