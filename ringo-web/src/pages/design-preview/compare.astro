---
// モバイル/PC比較表示：1画面でモバイル幅・PC幅を並べて確認できるビュー
// 各ページを実URLのままiframeで埋め込むため、実際の操作（スクロール・クリック）も可能
import ClaudePreviewLayout from '../../layouts/ClaudePreviewLayout.astro';
import { PATTERNS } from '../../data/claude/preview';

const CIRCLED = ['①', '②', '③', '④', '⑤', '⑥', '⑦', '⑧'];
const OPTIONS = [
	{ value: 'design-preview/existing', label: '既存実装' },
	...PATTERNS.map((p, i) => ({ value: `design-preview/claude/${p.slug}`, label: `パターン${CIRCLED[i]}` })),
];
---

<ClaudePreviewLayout title="モバイル/PC比較表示" theme="claude-index">
	<section class="cp-container compare-head">
		<p class="cp-eyebrow">DEVICE COMPARE</p>
		<h1>モバイル / PC 比較表示</h1>
		<p class="lead text-pretty">1画面でモバイル幅とPC幅を並べて確認できます。各枠は実ページなので、スクロールやクリックもそのまま操作できます。</p>

		<label class="select-label">
			表示パターン
			<select id="compare-select">
				{OPTIONS.map((o) => <option value={o.value}>{o.label}</option>)}
			</select>
		</label>
	</section>

	<section class="compare-grid">
		<div class="pane">
			<p class="pane-label">モバイル（375px）</p>
			<div class="frame-wrap mobile">
				<iframe id="frame-mobile" title="モバイル表示"></iframe>
			</div>
		</div>
		<div class="pane">
			<p class="pane-label">PC（1280px）</p>
			<div class="frame-wrap desktop">
				<iframe id="frame-desktop" title="PC表示"></iframe>
			</div>
		</div>
	</section>
</ClaudePreviewLayout>

<script>
	const baseUrl = import.meta.env.BASE_URL.replace(/\/?$/, '/');
	const select = document.getElementById('compare-select') as HTMLSelectElement;
	const mobileFrame = document.getElementById('frame-mobile') as HTMLIFrameElement;
	const desktopFrame = document.getElementById('frame-desktop') as HTMLIFrameElement;

	function setPath(path: string) {
		mobileFrame.src = baseUrl + path;
		desktopFrame.src = baseUrl + path;
		const url = new URL(location.href);
		url.searchParams.set('path', path);
		history.replaceState(null, '', url);
	}

	const params = new URLSearchParams(location.search);
	const initial = params.get('path') || select.value;
	if ([...select.options].some((o) => o.value === initial)) {
		select.value = initial;
	}
	setPath(select.value);
	select.addEventListener('change', () => setPath(select.value));
</script>

<style>
	.compare-head {
		padding-top: clamp(2.5rem, 6vw, 4rem);
		margin-bottom: 2rem;
		max-width: 860px;
	}
	.cp-eyebrow {
		color: var(--cp-primary);
		font-weight: 700;
		font-size: 0.8rem;
		letter-spacing: var(--cp-eyebrow-tracking);
		margin-bottom: 0.75rem;
	}
	h1 {
		font-size: clamp(1.9rem, 4.4vw, 2.6rem);
		margin-bottom: 0.75rem;
	}
	.lead {
		color: var(--cp-text-muted);
		margin-bottom: 1.5rem;
	}
	.select-label {
		display: inline-flex;
		align-items: center;
		gap: 0.6rem;
		font-weight: 700;
		color: var(--cp-heading);
	}
	.select-label select {
		font: inherit;
		padding: 0.5rem 0.8rem;
		border-radius: 8px;
		border: 1px solid var(--cp-border);
		background: var(--cp-surface);
		color: var(--cp-text);
	}

	.compare-grid {
		display: flex;
		gap: 1.5rem;
		align-items: flex-start;
		overflow-x: auto;
		padding: 0 var(--container-pad-x) var(--cp-section-gap);
	}
	.pane {
		flex: 0 0 auto;
	}
	.pane-label {
		font-size: 0.85rem;
		font-weight: 700;
		color: var(--cp-text-muted);
		margin-bottom: 0.5rem;
	}
	.frame-wrap {
		border: 1px solid var(--cp-border);
		border-radius: 10px;
		overflow: auto;
		resize: vertical;
		box-shadow: var(--cp-shadow);
	}
	.frame-wrap iframe {
		display: block;
		border: 0;
	}
	.frame-wrap.mobile {
		width: 375px;
		height: 700px;
	}
	.frame-wrap.mobile iframe {
		width: 375px;
		height: 700px;
	}
	.frame-wrap.desktop {
		width: 1280px;
		height: 700px;
	}
	.frame-wrap.desktop iframe {
		width: 1280px;
		height: 700px;
	}
</style>
