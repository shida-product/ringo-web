</ClaudePreviewLayout>

<style>
	.mag-label {
		font-family: var(--mag-label-font);
		letter-spacing: var(--cp-eyebrow-tracking);
		text-transform: uppercase;
		font-weight: 500;
		font-size: 0.78rem;
	}

	/* ---- и°®зіЩ ---- */
	.cover {
		padding-top: 2rem;
		margin-bottom: var(--cp-section-gap);
	}
	.cover-frame {
		border: 3px solid var(--cp-border);
		padding: clamp(1.25rem, 3vw, 2.5rem);
	}
	.cover-top,
	.cover-bottom {
		display: flex;
		justify-content: space-between;
		gap: 1rem;
		flex-wrap: wrap;
		align-items: center;
	}
	.cover-top {
		border-bottom: 1px solid var(--cp-border);
		padding-bottom: 0.9rem;
		margin-bottom: 2rem;
	}
	.cover-main {
		display: grid;
		grid-template-columns: auto minmax(280px, 1fr) 250px;
		gap: clamp(1.5rem, 4vw, 3rem);
		align-items: stretch;
		margin-bottom: 2rem;
	}
	h1 {
		font-size: clamp(2.4rem, 5.2vw, 3.9rem);
		line-height: 1.15;
		margin: 0;
		align-self: center;
	}
	.cover-kicker {
		display: block;
		color: var(--cp-accent);
		margin-bottom: 1rem;
	}
	.cover-photo {
		margin: 0;
		min-width: 0;
	}
	.cover-photo :global(img) {
		width: 100%;
		height: 100%;
		min-height: 320px;
		object-fit: cover;
	}
	.cover-lines {
		list-style: none;
		display: flex;
		flex-direction: column;
		justify-content: center;
		gap: 1.1rem;
		border-left: 1px solid var(--cp-border);
		padding-left: 1.5rem;
	}
	.cover-lines li {
		font-family: var(--cp-font-display);
		font-weight: 600;
		line-height: 1.6;
	}
	.cover-lines b {
		color: var(--cp-accent);
		font-family: var(--mag-label-font);
		margin-right: 0.4em;
	}
	.cover-lines .mag-label {
		display: inline-block;
		background: var(--cp-accent);
		color: #fff;
		padding: 0.1rem 0.5rem;
		margin-left: 0.4em;
	}
	.cover-cta {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		border-top: 1px solid var(--cp-border);
		padding-top: 1rem;
	}
	.cover-cta a {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		color: var(--cp-text);
		font-weight: 700;
		text-decoration: underline;
		text-underline-offset: 4px;
		text-decoration-color: var(--cp-accent);
		min-height: var(--tap-min);
	}
	.cover-cta :global(svg) {
		width: 17px;
		height: 17px;
		color: var(--cp-accent);
	}
	.cover-bottom {
		border-top: 1px solid var(--cp-border);
		padding-top: 0.9rem;
		font-size: 0.82rem;
		color: var(--cp-text-muted);
	}
	.barcode {
		width: 90px;
		height: 30px;
		background: repeating-linear-gradient(90deg, var(--cp-border) 0 2px, transparent 2px 5px, var(--cp-border) 5px 6px, transparent 6px 9px);
	}

	/* ---- и¶ЛеЗЇгБЧгГЂгГЉгГЦгГ™гГГгВѓ ---- */
	.rubric {
		display: flex;
		align-items: baseline;
		gap: 1.25rem;
		font-size: clamp(1.4rem, 3vw, 1.9rem);
		border-bottom: 3px solid var(--cp-border);
		padding-bottom: 0.7rem;
		margin-bottom: 2rem;
	}
	.rubric .mag-label {
		color: var(--cp-accent);
	}

	/* ---- гГҐгВґгВ§гВѓзЙєйЫЖ ---- */
	.mosaic {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 2rem;
	}
	.feature {
		color: var(--cp-text);
		display: flex;
		flex-direction: column;
	}
	.feature.is-lg {
		grid-row: span 2;
	}
	.feature figure {
		margin: 0 0 1.1rem;
		overflow: hidden;
	}
	.feature :global(img) {
		width: 100%;
		height: auto;
		aspect-ratio: 16 / 10;
		object-fit: cover;
		transition: transform 0.4s ease;
	}
	.feature:hover :global(img) {
		transform: scale(1.04);
	}
	.feature:hover {
		opacity: 1;
	}
	.feature.is-sm {
		border-top: 1px solid var(--cp-border);
		padding-top: 1.25rem;
	}
	.kicker {
		color: var(--cp-accent);
	}
	.feature h3 {
		font-size: clamp(1.3rem, 2.6vw, 1.8rem);
		margin: 0.5rem 0 0.6rem;
	}
	.feature p {
		color: var(--cp-text-muted);
		font-size: 0.95rem;
		max-width: 34em;
		margin-bottom: 0.9rem;
	}
	.readmore {
		display: inline-flex;
		align-items: center;
		gap: 0.2rem;
		color: var(--cp-text);
		border-bottom: 2px solid var(--cp-accent);
		align-self: flex-start;
		padding-bottom: 0.2rem;
	}
	.readmore :global(svg) {
		width: 14px;
		height: 14px;
	}
	.pull-quote {
		border-top: 1px solid var(--cp-border);
		padding-top: 1.25rem;
		display: flex;
		flex-direction: column;
		justify-content: center;
	}
	.pull-quote p {
		font-family: var(--cp-font-display);
		font-weight: 900;
		font-size: clamp(1.4rem, 3vw, 2rem);
		line-height: 1.6;
	}
	.pull-quote cite {
		color: var(--cp-text-muted);
		font-style: normal;
		margin-top: 0.75rem;
	}

	/* ---- гГРгВ§гГ§гГЉгВЇгВђгВ§гГЙ ---- */
	.guide {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 0 2.5rem;
	}
	.guide-item {
		display: flex;
		gap: 1.1rem;
		border-top: 1px solid var(--cp-border);
		padding: 1.5rem 0;
	}
	.guide-no {
		font-family: var(--mag-label-font);
		font-size: 2.8rem;
		line-height: 1;
		color: var(--cp-surface-alt);
		-webkit-text-stroke: 1.5px var(--cp-text);
	}
	.guide-meta {
		color: var(--cp-accent);
	}
	.guide h3 {
		font-size: 1.2rem;
		margin: 0.3rem 0 0.5rem;
	}
	.guide h3 a {
		color: var(--cp-text);
	}
	.guide h3 a:hover {
		color: var(--cp-accent);
		opacity: 1;
	}
	.guide-summary {
		font-size: 0.88rem;
		color: var(--cp-text-muted);
		margin-bottom: 0.6rem;
	}
	.guide-price {
		font-family: var(--mag-label-font);
		font-weight: 600;
	}

	/* ---- INFORMATION ---- */
	.info-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 3rem;
	}
	.info-col h3 {
		color: var(--cp-accent);
		margin-bottom: 0.9rem;
	}
	.info-col h3:not(:first-child) {
		margin-top: 1.75rem;
	}
	.info-col table {
		width: 100%;
		border-collapse: collapse;
		text-align: center;
		font-size: 0.92rem;
	}
	.info-col th,
	.info-col td {
		border: 1px solid var(--cp-border);
		padding: 0.5rem 0.3rem;
	}
	.info-col td.closed {
		color: var(--cp-text-muted);
	}
	.info-note {
		font-size: 0.85rem;
		color: var(--cp-text-muted);
		margin-top: 0.6rem;
	}
	.info-contact a {
		color: var(--cp-text);
		font-weight: 700;
		text-decoration: underline;
		text-underline-offset: 4px;
		text-decoration-color: var(--cp-accent);
		line-height: 2.2;
	}
	.info-access {
		line-height: 2;
		margin-bottom: 1rem;
	}
	.info-access a {
		color: var(--cp-text);
		text-decoration: underline;
		text-underline-offset: 4px;
	}
	.map-embed {
		border: 1px solid var(--cp-border);
		min-height: 280px;
	}
	.map-embed iframe {
		width: 100%;
		height: 100%;
		min-height: 280px;
		border: 0;
		display: block;
	}

	/* ---- и£Пи°®зіЩ ---- */
	.backcover {
		background: var(--cp-text);
		color: #fff;
		padding: clamp(3rem, 6vw, 4.5rem) 0;
	}
	.backcover-inner {
		text-align: center;
	}
	.backcover .mag-label {
		color: var(--cp-accent);
	}
	.backcover h2 {
		color: #fff;
		font-size: clamp(1.7rem, 4vw, 2.6rem);
		margin: 0.75rem 0 1.75rem;
	}
