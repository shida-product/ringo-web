];
---

<ClaudePreviewLayout title="Pharmacy Magazine" theme="pharmacy-magazine">

	<!-- и°®зіЩ -->
	<header class="cover cp-container">
		<div class="cover-frame">
			<p class="cover-top">
				<span class="mag-label">PHARMACY MAGAZINE</span>
