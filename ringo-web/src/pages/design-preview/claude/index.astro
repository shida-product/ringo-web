---
// Claude デザイン試作：パターン一覧（入口ページ）
// /design-preview/claude/ 配下は Claude が作成した試作。
// 一覧自体もカードグリッドではなく、番号付きの目録スタイルにする。
import ClaudePreviewLayout from '../../../layouts/ClaudePreviewLayout.astro';
import PreviewPatternNav from '../../../components/claude/PreviewPatternNav.astro';
import { PATTERNS } from '../../../data/claude/preview';

const baseUrl = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const previewBase = `${baseUrl}design-preview/claude/`;
---

<ClaudePreviewLayout title="デザイン試作一覧" theme="claude-index">
	<PreviewPatternNav />

	<section class="cp-container intro">
		<p class="cp-eyebrow">DESIGN PREVIEW BY CLAUDE</p>
		<h1>デザイン試作、8パターン。</h1>
		<p class="lead text-pretty">
			`docs/foundation/design-refresh-implementation-guide.md` に基づき、Claudeが作成した試作の目録です。
			各案はレイアウト構造・情報設計・UI装置から作り分けています。どの案でも、営業時間・電話・LINE・
			処方箋受付・市販薬相談・アクセスの必須情報は落としていません。
		</p>
	</section>

	<section class="cp-container catalog" aria-label="パターン一覧">
		<ol>
			{
				PATTERNS.map((pattern, i) => (
					<li data-reveal>
						<a href={`${previewBase}${pattern.slug}`}>
							<span class="no" aria-hidden="true">
								{String(i + 1).padStart(2, '0')}
							</span>
							<span class="body">
								<span class="head">
									<b class="name">{pattern.name}</b>
									<span class:list={['tag', { 'is-exp': pattern.tag !== '本番採用候補' }]}>{pattern.tag}</span>
								</span>
								<span class="concept text-pretty">{pattern.concept}</span>
							</span>
							<i data-lucide="chevron-right" aria-hidden="true" />
						</a>
					</li>
				))
			}
		</ol>
	</section>
</ClaudePreviewLayout>

<style>
	.intro {
		padding-top: clamp(2.5rem, 6vw, 4rem);
		margin-bottom: 3rem;
		max-width: 860px;
	}
	.cp-eyebrow {
		color: var(--cp-primary);
		font-weight: 700;
		font-size: 0.8rem;
		letter-spacing: var(--cp-eyebrow-tracking);
		margin-bottom: 0.75rem;
	}
	h1 {
		font-size: clamp(1.9rem, 4.4vw, 2.8rem);
		margin-bottom: 1rem;
	}
	.lead {
		color: var(--cp-text-muted);
	}
	.catalog {
		margin-bottom: var(--cp-section-gap);
	}
	.catalog ol {
		list-style: none;
		border-top: 2px solid var(--cp-heading);
	}
	.catalog a {
		display: grid;
		grid-template-columns: auto 1fr auto;
		align-items: center;
		gap: 1.75rem;
		padding: 1.5rem 0.5rem;
		border-bottom: 1px solid var(--cp-border);
		color: var(--cp-text);
		transition: background 0.2s ease, padding-left 0.25s ease;
	}
	.catalog a:hover {
		background: var(--cp-surface);
		padding-left: 1.25rem;
		opacity: 1;
	}
	.no {
		font-size: 1.9rem;
		font-weight: 700;
		color: var(--cp-primary);
		font-variant-numeric: tabular-nums;
	}
	.head {
		display: flex;
		align-items: center;
		gap: 0.9rem;
		flex-wrap: wrap;
		margin-bottom: 0.35rem;
	}
	.name {
		font-size: 1.25rem;
		color: var(--cp-heading);
	}
	.tag {
		background: var(--cp-primary);
		color: var(--cp-primary-contrast);
		font-size: 0.72rem;
		font-weight: 700;
		padding: 0.18rem 0.7rem;
		border-radius: 9999px;
	}
	.tag.is-exp {
		background: var(--cp-surface-alt);
		color: var(--cp-text-muted);
	}
	.concept {
		display: block;
		font-size: 0.92rem;
		color: var(--cp-text-muted);
		max-width: 52em;
	}
	.catalog :global(svg) {
		width: 22px;
		height: 22px;
		color: var(--cp-primary);
	}

	@media (max-width: 768px) {
		.catalog a {
			grid-template-columns: auto 1fr;
		}
		.catalog :global(svg) {
			display: none;
		}
	}
</style>
