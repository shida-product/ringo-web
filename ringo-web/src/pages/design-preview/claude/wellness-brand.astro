---
// Claude デザイン試作 6/8：Wellness Brand（表現検証）
// コンセプト：フルブリード写真、50/50の交互分割、索引番号と細罫。
// カード・影・角丸を使わず、余白とタイポグラフィで見せるブランド案。
import '../../../styles/claude/themes/wellness-brand.css';
import { Image } from 'astro:assets';
import ClaudePreviewLayout from '../../../layouts/ClaudePreviewLayout.astro';
import { getAllProducts, formatPrice } from '../../../data/products';
import { HOURS, MAP_EMBED_SRC } from '../../../data/claude/preview';
import { SITE } from '../../../data/site';
import photoIntrospection from '../../../assets/images/Introspection.jpg';
import photoSupport from '../../../assets/images/Support.jpg';
import photoProducts from '../../../assets/images/Products.jpg';

const baseUrl = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const products = getAllProducts();

const chapters = [
	{
		no: '01',
		label: 'Prescription',
		title: '処方箋は、待たずに。',
		body: '医療機関の処方箋にもとづき、お薬をお渡しします。LINEで処方箋の写真を送っておけば、来局前に準備を始められます。店頭での時間は、説明と相談のために。',
		photo: photoSupport,
		alt: '薬剤師による服薬相談の様子',
		href: 'prescription',
		linkLabel: '処方箋受付について',
	},
	{
		no: '02',
		label: 'Consultation',
		title: '相談は、日常のなかに。',
		body: 'かぜ薬やビタミン剤の選び方、お薬代を抑えるジェネリックへの変更、なんとなく続く不調のこと。病院に行くほどではない「気がかり」を、暮らしのそばで受けとめます。',
		photo: photoIntrospection,
		alt: 'りんごちゃん薬局の店内',
		href: 'generic',
		linkLabel: 'ジェネリック相談について',
	},
	{
		no: '03',
		label: 'Selection',
		title: '棚には、理由のあるものだけ。',
		body: '市販薬やヘルスケア用品を、相談の多い順に取り揃えています。店頭にない商品も取り寄せの相談ができます。選ぶ理由を、薬剤師がことばで説明します。',
		photo: photoProducts,
		alt: '店内の市販薬陳列棚',
		href: 'products',
		linkLabel: '取扱い商品を見る',
	},
];
---

<ClaudePreviewLayout title="Wellness Brand" theme="wellness-brand">

	<!-- フルスクリーンヒーロー -->
	<header class="hero">
		<Image src={photoIntrospection} alt="" class="hero-bg" widths={[800, 1200, 1920]} sizes="100vw" loading="eager" />
		<div class="hero-veil"></div>
		<div class="hero-center">
			<p class="hero-eyebrow cp-eyebrow">Everyday Wellness — Machiya, Arakawa</p>
			<h1 class="text-balance">健やかな毎日は、<br />近所の薬局から。</h1>
			<p class="hero-foot">{SITE.name}｜町屋駅 徒歩5分｜土日も営業</p>
		</div>
		<span class="hero-scroll" aria-hidden="true"></span>
	</header>

	<!-- ステートメント -->
	<section class="statement cp-container" data-reveal>
		<p class="text-balance">
			薬を渡すだけの場所ではなく、<br class="br-pc-only" />
			体調の「ちょっと手前」から寄り添う場所へ。
		</p>
	</section>

	<!-- 50/50チャプター -->
	{
		chapters.map((chapter, i) => (
			<section class:list={['chapter', { 'is-flip': i % 2 === 1 }]} aria-labelledby={`ch-${chapter.no}`}>
				<figure class="chapter-photo">
					<Image src={chapter.photo} alt={chapter.alt} widths={[600, 900, 1400]} sizes="(max-width: 900px) 100vw, 50vw" />
				</figure>
				<div class="chapter-text" data-reveal>
					<p class="chapter-no cp-eyebrow">
						{chapter.no} — {chapter.label}
					</p>
					<h2 id={`ch-${chapter.no}`}>{chapter.title}</h2>
					<p class="chapter-body text-pretty">{chapter.body}</p>
					<a class="chapter-link" href={`${baseUrl}${chapter.href}`}>
						{chapter.linkLabel}
						<i data-lucide="chevron-right" aria-hidden="true" />
					</a>
				</div>
			</section>
		))
	}

	<!-- 商品：ミニマルなリスト -->
	<section class="cp-section cp-container items" aria-labelledby="items-title">
		<p class="cp-eyebrow">Selected Items</p>
		<h2 id="items-title">取扱い商品（一例）</h2>
		<ul>
			{
				products.map((product) => (
					<li data-reveal>
						<a href={`${baseUrl}products/${product.slug}`}>
							<span class="item-name">{product.name}</span>
							<span class="item-meta">
								{product.category}・{product.medClass}
							</span>
							<span class="item-price">{formatPrice(product.price)}</span>
						</a>
					</li>
				))
			}
		</ul>
		<p class="cp-note">※商品情報はサンプルです。正式公開時にmicroCMSのデータへ差し替えます。</p>
	</section>

	<!-- 営業時間：タイポグラフィで ---->
	<section class="cp-section hours" aria-labelledby="hours-title">
		<div class="cp-container">
			<p class="cp-eyebrow">Opening Hours</p>
			<h2 id="hours-title" class="visually-plain">営業時間</h2>
			<div class="hours-rows">
				{
					HOURS.summary.map((s) => (
						<div class="hours-row" data-reveal>
							<span class="hr-label">{s.label}</span>
							<span class="hr-value">{s.value}</span>
						</div>
					))
				}
			</div>
			<p class="hours-note">{HOURS.holiday}（{HOURS.holidayNote.replace('※', '')}）／日曜は12:30まで、土曜は13:00までの営業です。</p>
		</div>
	</section>

	<!-- アクセス -->
	<section class="access" aria-labelledby="access-title">
		<div class="map-embed">
			<iframe
				src={MAP_EMBED_SRC}
				title="りんごちゃん薬局 地図"
				loading="lazy"
				referrerpolicy="no-referrer-when-downgrade"></iframe>
		</div>
		<div class="access-lines cp-container">
			<p class="cp-eyebrow">Access</p>
			<h2 id="access-title" class="visually-plain">アクセス</h2>
			<p class="access-main">町屋駅（千代田線・さくらトラム）徒歩5分</p>
			<p class="access-addr">
				{SITE.postalCode}
				<a href={SITE.mapUrl} target="_blank" rel="noopener noreferrer">
					{SITE.address} <i data-lucide="external-link" aria-hidden="true"></i>
				</a>
			</p>
		</div>
	</section>

	<!-- CTA：一行 -->
	<section class="cta cp-container" data-reveal>
		<p class="cta-line text-balance">今日の不調も、明日の予防も。</p>
		<div class="cta-links">
			<a href={SITE.lineUrl} target="_blank" rel="noopener noreferrer">
				<i data-lucide="message-circle" aria-hidden="true"></i>LINEで事前受付
			</a>
			<span aria-hidden="true">／</span>
			<a href={SITE.telLink}><i data-lucide="phone" aria-hidden="true"></i>{SITE.tel}</a>
		</div>
	</section>
</ClaudePreviewLayout>

<style>
	/* ---- ヒーロー ---- */
	.hero {
		position: relative;
		min-height: min(88vh, 780px);
		display: flex;
		align-items: center;
		justify-content: center;
		overflow: hidden;
		margin-bottom: var(--cp-section-gap);
	}
	.hero :global(.hero-bg) {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
	}
	.hero-veil {
		position: absolute;
		inset: 0;
		background: rgba(26, 34, 30, 0.62);
	}
	.hero-center {
		position: relative;
		text-align: center;
		color: #fff;
		padding: 0 var(--container-pad-x);
	}
	.hero-eyebrow {
		color: #d8c9a8;
		letter-spacing: var(--cp-eyebrow-tracking);
		text-transform: uppercase;
		margin-bottom: 1.5rem;
	}
	.hero-center h1 {
		color: #fff;
		font-size: clamp(2.1rem, 5.5vw, 3.6rem);
		font-weight: 500;
		line-height: 1.5;
		letter-spacing: 0.08em;
		margin-bottom: 1.75rem;
		text-shadow: 0 2px 20px rgba(0, 0, 0, 0.35);
	}
	.hero-foot {
		font-size: 0.95rem;
		letter-spacing: 0.14em;
		opacity: 0.85;
	}
	.hero-scroll {
		position: absolute;
		bottom: 2rem;
		left: 50%;
		width: 1px;
		height: 56px;
		background: rgba(255, 255, 255, 0.7);
		animation: hero-scroll 2.2s ease-in-out infinite;
	}
	@keyframes hero-scroll {
		0% {
			transform: scaleY(0);
			transform-origin: top;
		}
		45% {
			transform: scaleY(1);
			transform-origin: top;
		}
		55% {
			transform: scaleY(1);
			transform-origin: bottom;
		}
		100% {
			transform: scaleY(0);
			transform-origin: bottom;
		}
	}

	/* ---- ステートメント ---- */
	.statement {
		text-align: center;
		margin-bottom: var(--cp-section-gap);
	}
	.statement p {
		font-size: clamp(1.3rem, 3vw, 1.9rem);
		line-height: 2;
		letter-spacing: 0.1em;
		color: var(--cp-heading);
	}

	/* ---- チャプター（50/50） ---- */
	.chapter {
		display: grid;
		grid-template-columns: 1fr 1fr;
		min-height: 520px;
		margin-bottom: var(--cp-section-gap);
	}
	.chapter.is-flip .chapter-photo {
		order: 2;
	}
	.chapter-photo {
		margin: 0;
	}
	.chapter-photo :global(img) {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}
	.chapter-text {
		display: flex;
		flex-direction: column;
		justify-content: center;
		padding: clamp(2.5rem, 6vw, 5rem);
		background: var(--cp-surface-alt);
	}
	.chapter-no {
		color: var(--cp-accent);
		letter-spacing: var(--cp-eyebrow-tracking);
		text-transform: uppercase;
		margin-bottom: 1.25rem;
	}
	.chapter-text h2 {
		font-size: clamp(1.6rem, 3.4vw, 2.3rem);
		font-weight: 500;
		letter-spacing: 0.06em;
		margin-bottom: 1.25rem;
	}
	.chapter-body {
		color: var(--cp-text-muted);
		line-height: 2.1;
		max-width: 30em;
		margin-bottom: 2rem;
	}
	.chapter-link {
		display: inline-flex;
		align-items: center;
		gap: 0.3rem;
		color: var(--cp-heading);
		font-weight: 500;
		letter-spacing: 0.06em;
		border-bottom: 1px solid var(--cp-heading);
		padding-bottom: 0.35rem;
		align-self: flex-start;
		min-height: var(--tap-min);
	}
	.chapter-link:hover {
		color: var(--cp-accent);
		border-color: var(--cp-accent);
		opacity: 1;
	}
	.chapter-link :global(svg) {
		width: 16px;
		height: 16px;
	}

	/* ---- 商品リスト ---- */
	.items h2 {
		font-size: clamp(1.5rem, 3vw, 2rem);
		font-weight: 500;
		margin: 0.5rem 0 2.25rem;
	}
	.items .cp-eyebrow {
		color: var(--cp-accent);
		letter-spacing: var(--cp-eyebrow-tracking);
		text-transform: uppercase;
	}
	.items ul {
		list-style: none;
		border-top: 1px solid var(--cp-border);
	}
	.items a {
		display: grid;
		grid-template-columns: 1fr auto auto;
		gap: 2rem;
		align-items: baseline;
		padding: 1.6rem 0.25rem;
		border-bottom: 1px solid var(--cp-border);
		color: var(--cp-text);
		transition: padding-left 0.25s ease;
	}
	.items a:hover {
		padding-left: 1rem;
		opacity: 1;
		color: var(--cp-heading);
	}
	.item-name {
		font-size: 1.2rem;
		font-weight: 500;
		letter-spacing: 0.04em;
	}
	.item-meta {
		font-size: 0.85rem;
		color: var(--cp-text-muted);
	}
	.item-price {
		font-variant-numeric: tabular-nums;
		color: var(--cp-heading);
	}

	/* ---- 営業時間 ---- */
	.hours {
		background: var(--cp-heading);
		color: #eef0ec;
		padding: clamp(3.5rem, 7vw, 5.5rem) 0;
	}
	.hours .cp-eyebrow {
		color: #d8c9a8;
		letter-spacing: var(--cp-eyebrow-tracking);
		text-transform: uppercase;
	}
	.visually-plain {
		position: absolute;
		width: 1px;
		height: 1px;
		overflow: hidden;
		clip-path: inset(50%);
	}
	.hours-rows {
		margin-top: 1.5rem;
		border-top: 1px solid rgba(255, 255, 255, 0.25);
	}
	.hours-row {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: 2rem;
		padding: 1.4rem 0.25rem;
		border-bottom: 1px solid rgba(255, 255, 255, 0.25);
	}
	.hr-label {
		font-size: 1.05rem;
		letter-spacing: 0.2em;
	}
	.hr-value {
		font-size: clamp(1.9rem, 5vw, 3rem);
		font-weight: 500;
		font-variant-numeric: tabular-nums;
		letter-spacing: 0.06em;
	}
	.hours-note {
		margin-top: 1.25rem;
		font-size: 0.9rem;
		opacity: 0.75;
	}

	/* ---- アクセス ---- */
	.access {
		margin-bottom: var(--cp-section-gap);
	}
	.map-embed {
		height: clamp(320px, 48vw, 460px);
		filter: grayscale(1);
	}
	.map-embed iframe {
		width: 100%;
		height: 100%;
		border: 0;
		display: block;
	}
	.access-lines {
		text-align: center;
		padding-top: 2.5rem;
	}
	.access-lines .cp-eyebrow {
		color: var(--cp-accent);
		letter-spacing: var(--cp-eyebrow-tracking);
		text-transform: uppercase;
	}
	.access-main {
		font-size: clamp(1.15rem, 2.6vw, 1.5rem);
		color: var(--cp-heading);
		margin: 0.75rem 0 0.5rem;
		letter-spacing: 0.06em;
	}
	.access-addr a {
		color: var(--cp-text);
		text-decoration: underline;
		text-underline-offset: 5px;
		text-decoration-color: var(--cp-border);
		display: inline-flex;
		align-items: center;
		gap: 0.3rem;
	}
	.access-addr :global(svg) {
		width: 15px;
		height: 15px;
	}

	/* ---- CTA ---- */
	.cta {
		text-align: center;
		margin-bottom: var(--cp-section-gap);
	}
	.cta-line {
		font-size: clamp(1.4rem, 3.2vw, 2rem);
		letter-spacing: 0.1em;
		color: var(--cp-heading);
		margin-bottom: 1.75rem;
	}
	.cta-links {
		display: inline-flex;
		align-items: center;
		gap: 1.25rem;
		color: var(--cp-border);
	}
	.cta-links a {
		display: inline-flex;
		align-items: center;
		gap: 0.45rem;
		font-weight: 500;
		font-size: 1.1rem;
		color: var(--cp-heading);
		border-bottom: 1px solid var(--cp-heading);
		padding-bottom: 0.3rem;
		min-height: var(--tap-min);
	}
	.cta-links a:hover {
		color: var(--cp-accent);
		border-color: var(--cp-accent);
		opacity: 1;
	}
	.cta-links :global(svg) {
		width: 19px;
		height: 19px;
	}

	@media (prefers-reduced-motion: reduce) {
		.hero-scroll {
			animation: none;
		}
	}
	@media (max-width: 900px) {
		.chapter {
			grid-template-columns: 1fr;
			min-height: 0;
		}
		.chapter.is-flip .chapter-photo {
			order: 0;
		}
		.chapter-photo :global(img) {
			aspect-ratio: 16 / 10;
		}
		.items a {
			grid-template-columns: 1fr;
			gap: 0.2rem;
		}
		.hours-row {
			flex-direction: column;
			gap: 0.2rem;
			align-items: flex-start;
		}
	}
</style>
