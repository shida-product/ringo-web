---
import PreviewLayout from '../../layouts/PreviewLayout.astro';
import ActionLinks from '../../components/ActionLinks.astro';
import HoursPanel from '../../components/HoursPanel.astro';
import AccessPanel from '../../components/AccessPanel.astro';
import CtaBand from '../../components/CtaBand.astro';
import PreviewPatternNav from '../../components/PreviewPatternNav.astro';
import support from '../../assets/images/Support.jpg';
---
<PreviewLayout title="Ringo Pop" theme="ringo-pop" description="Codex再作成版。りんごモチーフで親しみを強めるデザイン案です。">
  <article class="codex-pattern pattern-ringo"><section class="ringo-hero"><div class="ringo-orb" aria-hidden="true"></div><div class="preview-container"><PreviewPatternNav /><div class="ringo-grid"><div><span class="codex-kicker">Codex redesign / Ringo Pop</span><h1>相談しやすい、まちのりんご。</h1><p class="codex-lede">かわいさを背景グラフィックに寄せ、本文は読みやすく。名前の覚えやすさを最大化する案です。</p><ActionLinks /></div><div class="ringo-bubbles"><article><strong>処方箋</strong><small>LINEで先に送信</small></article><article><strong>市販薬</strong><small>症状に合わせて相談</small></article><article><strong>健康相談</strong><small>家族の薬も相談</small></article></div></div></div></section><section class="preview-section"><div class="preview-container ringo-layout"><div class="codex-photo"><img src={support.src} alt="薬局で相談する様子" /></div><div><HoursPanel /><AccessPanel /></div></div></section><section class="preview-section"><div class="preview-container"><CtaBand title="りんごちゃん薬局に相談する" text="丸みのあるカードと明るい導線で、初めての相談のハードルを下げます。" /></div></section></article>
</PreviewLayout>
