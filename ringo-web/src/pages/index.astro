---
// デザインパターン比較ツール（Pagesのトップページ）
// 上部ヘッダーでパターンを切り替え、モバイル幅・PC幅を並べて確認する。
// 各枠は実ページのiframeなので、スクロールやクリックもそのまま操作できる。
import '../styles/global.css';
import '../styles/claude/preview-tokens.css';
import { PATTERNS } from '../data/claude/preview';
import { SITE } from '../data/site';

const baseUrl = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const CIRCLED = ['①', '②', '③', '④', '⑤', '⑥', '⑦', '⑧', '⑨', '⑩'];
const OPTIONS = [
	{ value: 'design-preview/existing', label: '既存実装' },
	...PATTERNS.map((p, i) => ({ value: `design-preview/claude/${p.slug}`, label: `${CIRCLED[i]} ${p.short}` })),
];
---

<!doctype html>
<html lang="ja">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="デザインパターンをモバイル/PC並列表示で切り替えて比較するページ" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="robots" content="noindex, nofollow" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>デザインパターン比較 | {SITE.name}</title>
	</head>
	<body>
		<header class="switcher-head">
			<p class="head-title">DESIGN PREVIEW</p>
			<nav class="pattern-tabs" aria-label="デザインパターン切り替え">
				{
					OPTIONS.map((o, i) => (
						<button type="button" data-path={o.value} aria-pressed={i === 0 ? 'true' : 'false'}>
							{o.label}
						</button>
					))
				}
			</nav>
		</header>

		<main class="compare-area">
			<section class="pane mobile">
				<h2 class="pane-label">モバイル（375px）</h2>
				<div class="frame-wrap">
					<iframe id="frame-mobile" title="モバイル表示"></iframe>
				</div>
			</section>
			<section class="pane desktop">
				<h2 class="pane-label">PC（1280px）</h2>
				<div class="frame-wrap">
					<iframe id="frame-desktop" title="PC表示"></iframe>
				</div>
			</section>
		</main>

		<script>
			const baseUrl = import.meta.env.BASE_URL.replace(/\/?$/, '/');
			const buttons = [...document.querySelectorAll<HTMLButtonElement>('.pattern-tabs button')];
			const mobileFrame = document.getElementById('frame-mobile') as HTMLIFrameElement;
			const desktopFrame = document.getElementById('frame-desktop') as HTMLIFrameElement;

			let currentPath = '';

			function setPath(path: string) {
				if (path === currentPath) return;
				currentPath = path;
				mobileFrame.src = baseUrl + path;
				desktopFrame.src = baseUrl + path;
				for (const button of buttons) {
					button.setAttribute('aria-pressed', String(button.dataset.path === path));
				}
				const url = new URL(location.href);
				url.searchParams.set('p', path);
				history.replaceState(null, '', url);
			}

			const requested = new URLSearchParams(location.search).get('p');
			const initial = buttons.find((b) => b.dataset.path === requested) ?? buttons[0];
			setPath(initial.dataset.path!);

			for (const button of buttons) {
				button.addEventListener('click', () => setPath(button.dataset.path!));
			}
		</script>

		<style>
			html,
			body {
				height: 100%;
			}
			body {
				display: flex;
				flex-direction: column;
				background: #eceff0;
				color: var(--cp-text);
				font-family: var(--cp-font-body);
			}

			/* 上部ヘッダー：タイトル＋パターン切り替えタブ */
			.switcher-head {
				flex: none;
				display: flex;
				align-items: center;
				gap: 1.25rem;
				background: #14211d;
				color: #e8ede9;
				padding: 0.55rem var(--container-pad-x);
			}
			.head-title {
				color: #ffd166;
				font-weight: 700;
				font-size: 0.8rem;
				letter-spacing: 0.14em;
				white-space: nowrap;
			}
			.pattern-tabs {
				display: flex;
				gap: 0.25rem;
				overflow-x: auto;
				-webkit-overflow-scrolling: touch;
			}
			.pattern-tabs button {
				appearance: none;
				border: 0;
				background: none;
				font: inherit;
				font-size: 0.82rem;
				color: #e8ede9;
				white-space: nowrap;
				padding: 0.5rem 0.7rem;
				min-height: var(--tap-min);
				border-radius: 6px;
				cursor: pointer;
			}
			.pattern-tabs button:hover {
				background: rgba(255, 255, 255, 0.12);
			}
			.pattern-tabs button[aria-pressed='true'] {
				background: rgba(255, 209, 102, 0.18);
				color: #ffd166;
				font-weight: 700;
			}

			/* 比較エリア：モバイル/PCを横並び（画面に収まらない分は横スクロール） */
			.compare-area {
				flex: 1;
				min-height: 0;
				display: flex;
				align-items: stretch;
				gap: 1.25rem;
				overflow-x: auto;
				padding: 1rem var(--container-pad-x) 1.25rem;
			}
			.pane {
				flex: none;
				display: flex;
				flex-direction: column;
				min-height: 0;
			}
			.pane.mobile {
				width: 375px;
			}
			.pane.desktop {
				width: 1280px;
			}
			.pane-label {
				flex: none;
				font-size: 0.8rem;
				font-weight: 700;
				color: var(--cp-text-muted);
				margin-bottom: 0.4rem;
			}
			.frame-wrap {
				flex: 1;
				min-height: 480px;
				border: 1px solid var(--cp-border);
				border-radius: 10px;
				overflow: hidden;
				background: #fff;
				box-shadow: var(--cp-shadow);
			}
			.frame-wrap iframe {
				display: block;
				border: 0;
				width: 100%;
				height: 100%;
			}

			@media (max-width: 768px) {
				.switcher-head {
					flex-direction: column;
					align-items: flex-start;
					gap: 0;
				}
				.pattern-tabs {
					width: 100%;
				}
			}
		</style>
	</body>
</html>
