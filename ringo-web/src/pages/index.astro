---
// デザインパターン比較ツール（Pagesのトップページ）
// 上部ヘッダーでパターンを切り替え、モバイル幅・PC幅の実ページをiframeで確認する。
// 閲覧環境ごとに最適なUIに分ける：
// - PC閲覧：モバイル(375px実寸) と PC(1280px→枠幅に縮小) を並列表示
// - モバイル閲覧：デバイストグルで1枠ずつ全画面表示
import '../styles/global.css';
import '../styles/claude/preview-tokens.css';
import { PATTERNS } from '../data/claude/preview';
import { SITE } from '../data/site';

const baseUrl = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const CIRCLED = ['①', '②', '③', '④', '⑤', '⑥', '⑦', '⑧', '⑨', '⑩'];
const OPTIONS = [
	{ value: 'design-preview/existing', label: '既存実装' },
	...PATTERNS.map((p, i) => ({ value: `design-preview/claude/${p.slug}`, label: `${CIRCLED[i]} ${p.short}` })),
];
---

<!doctype html>
<html lang="ja">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="デザインパターンをモバイル/PC表示で切り替えて比較するページ" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="robots" content="noindex, nofollow" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>デザインパターン比較 | {SITE.name}</title>
	</head>
	<body>
		<header class="switcher-head">
			<p class="head-title">DESIGN PREVIEW</p>
			<nav class="pattern-tabs" aria-label="デザインパターン切り替え">
				{
					OPTIONS.map((o, i) => (
						<button type="button" data-path={o.value} aria-pressed={i === 0 ? 'true' : 'false'}>
							{o.label}
						</button>
					))
				}
			</nav>
			<!-- モバイル閲覧時のみ表示：プレビューのデバイス切り替え -->
			<div class="device-toggle" role="group" aria-label="表示デバイス切り替え">
				<button type="button" data-device="mobile" aria-pressed="true">モバイル</button>
				<button type="button" data-device="desktop" aria-pressed="false">PC</button>
			</div>
		</header>

		<main class="compare-area" data-device="mobile">
			<section class="pane mobile">
				<h2 class="pane-label">モバイル（375px）</h2>
				<div class="frame-wrap" data-width="375">
					<iframe id="frame-mobile" title="モバイル表示"></iframe>
				</div>
			</section>
			<section class="pane desktop">
				<h2 class="pane-label">PC（1280px）</h2>
				<div class="frame-wrap" data-width="1280">
					<iframe id="frame-desktop" title="PC表示"></iframe>
				</div>
			</section>
		</main>

		<script>
			const baseUrl = import.meta.env.BASE_URL.replace(/\/?$/, '/');
			const patternButtons = [...document.querySelectorAll<HTMLButtonElement>('.pattern-tabs button')];
			const deviceButtons = [...document.querySelectorAll<HTMLButtonElement>('.device-toggle button')];
			const area = document.querySelector('.compare-area') as HTMLElement;
			const mobileFrame = document.getElementById('frame-mobile') as HTMLIFrameElement;
			const desktopFrame = document.getElementById('frame-desktop') as HTMLIFrameElement;
			const wraps = [...document.querySelectorAll<HTMLElement>('.frame-wrap')];

			// --- iframeは実寸で描画し、枠のサイズに合わせて縮小表示 ---
			function fit(wrap: HTMLElement) {
				const iframe = wrap.querySelector('iframe');
				if (!iframe || wrap.clientWidth === 0) return;
				const targetWidth = Number(wrap.dataset.width);
				const scale = Math.min(1, wrap.clientWidth / targetWidth);
				iframe.style.width = `${targetWidth}px`;
				iframe.style.height = `${Math.round(wrap.clientHeight / scale)}px`;
				iframe.style.transform = `scale(${scale})`;
			}

			const ro = new ResizeObserver((entries) => {
				for (const entry of entries) fit(entry.target as HTMLElement);
			});
			for (const wrap of wraps) ro.observe(wrap);

			// --- パターン切り替え ---
			let currentPath = '';

			function setPath(path: string) {
				if (path === currentPath) return;
				currentPath = path;
				mobileFrame.src = baseUrl + path;
				desktopFrame.src = baseUrl + path;
				for (const button of patternButtons) {
					button.setAttribute('aria-pressed', String(button.dataset.path === path));
				}
				const url = new URL(location.href);
				url.searchParams.set('p', path);
				history.replaceState(null, '', url);
			}

			// --- デバイス切り替え（モバイル閲覧時のみ意味を持つ） ---
			function setDevice(device: string) {
				area.dataset.device = device;
				for (const button of deviceButtons) {
					button.setAttribute('aria-pressed', String(button.dataset.device === device));
				}
				for (const wrap of wraps) fit(wrap);
			}

			const params = new URLSearchParams(location.search);
			const requested = params.get('p');
			const initial = patternButtons.find((b) => b.dataset.path === requested) ?? patternButtons[0];
			setPath(initial.dataset.path!);
			for (const wrap of wraps) fit(wrap);

			for (const button of patternButtons) {
				button.addEventListener('click', () => setPath(button.dataset.path!));
			}
			for (const button of deviceButtons) {
				button.addEventListener('click', () => setDevice(button.dataset.device!));
			}
		</script>

		<style>
			html,
			body {
				height: 100%;
			}
			body {
				display: flex;
				flex-direction: column;
				background: #eceff0;
				color: var(--cp-text);
				font-family: var(--cp-font-body);
			}

			/* 上部ヘッダー：タイトル＋パターン切り替えタブ */
			.switcher-head {
				flex: none;
				display: flex;
				align-items: center;
				gap: 1.25rem;
				background: #14211d;
				color: #e8ede9;
				padding: 0.55rem var(--container-pad-x);
			}
			.head-title {
				color: #ffd166;
				font-weight: 700;
				font-size: 0.8rem;
				letter-spacing: 0.14em;
				white-space: nowrap;
			}
			.pattern-tabs {
				display: flex;
				gap: 0.25rem;
				overflow-x: auto;
				-webkit-overflow-scrolling: touch;
			}
			.pattern-tabs button,
			.device-toggle button {
				appearance: none;
				border: 0;
				background: none;
				font: inherit;
				font-size: 0.82rem;
				color: #e8ede9;
				white-space: nowrap;
				padding: 0.5rem 0.7rem;
				min-height: var(--tap-min);
				border-radius: 6px;
				cursor: pointer;
			}
			.pattern-tabs button:hover {
				background: rgba(255, 255, 255, 0.12);
			}
			.pattern-tabs button[aria-pressed='true'] {
				background: rgba(255, 209, 102, 0.18);
				color: #ffd166;
				font-weight: 700;
			}

			/* デバイストグル：PC閲覧では両方並ぶので不要 */
			.device-toggle {
				display: none;
			}

			/* ============================================================
			   PC閲覧：モバイル(実寸) と PC(縮小) の並列表示
			   ============================================================ */
			.compare-area {
				flex: 1;
				min-height: 0;
				display: flex;
				align-items: stretch;
				gap: 1.25rem;
				padding: 1rem var(--container-pad-x) 1.25rem;
			}
			.pane {
				display: flex;
				flex-direction: column;
				min-height: 0;
				min-width: 0;
			}
			.pane.mobile {
				flex: none;
				width: 375px;
			}
			.pane.desktop {
				flex: 1 1 0;
				max-width: 1280px;
			}
			.pane-label {
				flex: none;
				font-size: 0.8rem;
				font-weight: 700;
				color: var(--cp-text-muted);
				margin-bottom: 0.4rem;
			}
			.frame-wrap {
				flex: 1;
				min-height: 0;
				border: 1px solid var(--cp-border);
				border-radius: 10px;
				overflow: hidden;
				background: #fff;
				box-shadow: var(--cp-shadow);
			}
			.frame-wrap iframe {
				display: block;
				border: 0;
				transform-origin: top left;
			}

			/* ============================================================
			   モバイル閲覧：デバイストグルで1枠ずつ全画面表示
			   ============================================================ */
			@media (max-width: 860px) {
				.switcher-head {
					flex-wrap: wrap;
					row-gap: 0.25rem;
					padding-bottom: 0.55rem;
				}
				.head-title {
					flex: 1;
				}
				.device-toggle {
					display: flex;
					gap: 0.25rem;
					background: rgba(255, 255, 255, 0.08);
					border-radius: 8px;
					padding: 0.15rem;
					order: 2;
				}
				.device-toggle button {
					min-height: 36px;
					padding: 0.25rem 0.8rem;
				}
				.device-toggle button[aria-pressed='true'] {
					background: rgba(255, 209, 102, 0.22);
					color: #ffd166;
					font-weight: 700;
				}
				.pattern-tabs {
					order: 3;
					width: 100%;
				}

				.compare-area {
					padding: 0.6rem 0.6rem 0.75rem;
					gap: 0;
				}
				/* トグルで選ばれていない方の枠は描画したまま隠す（再読み込みさせない） */
				.compare-area[data-device='mobile'] .pane.desktop,
				.compare-area[data-device='desktop'] .pane.mobile {
					display: none;
				}
				.pane.mobile {
					flex: 1 1 auto;
					width: min(375px, 100%);
					margin-inline: auto;
				}
				.pane.desktop {
					flex: 1 1 auto;
					width: 100%;
					max-width: none;
				}
				/* トグルがデバイス名を示すのでラベルは省略 */
				.pane-label {
					display: none;
				}
			}
		</style>
	</body>
</html>
